# ============================================================
# Google Form Clone — Backend Environment Variables Template
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# Django
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-django-secret-key-here

# Set to False in production
DEBUG=True

# Comma-separated. Example: localhost,127.0.0.1,yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================
# Encryption (for share links)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key())"
# ============================================================
ENCRYPTION_KEY=your-fernet-key-here

# ============================================================
# Email (SMTP)
# ============================================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
# Use an App Password if you have 2FA enabled on Gmail
EMAIL_HOST_PASSWORD=your-email-app-password

# ============================================================
# CORS (for frontend <-> backend communication)
# ============================================================
CORS_ALLOWED_ORIGINS=http://localhost:8001,http://127.0.0.1:8001
